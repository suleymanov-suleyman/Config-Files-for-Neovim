#This file for hyprland ml4w keybinds/default.conf
#Just replace settings
input {
    kb_options = caps:escape
    kb_options = caps:swapescape
}

bind = $mainMod, grave, killactive                                                              # Kill active window

bind = $mainMod, `, togglesplit                                                             # Toggle split
bind = $mainMod, j, movefocus, l                                                         # Move focus left
bind = $mainMod, semicolon, movefocus, r                                                        # Move focus right
bind = $mainMod, l, movefocus, u                                                           # Move focus up
bind = $mainMod, k, movefocus, d                                                         # Move focus down

bind = $mainMod SHIFT, j, resizeactive, 100 0                                           # Increase window width with keyboard
bind = $mainMod SHIFT, semicolon, resizeactive, -100 0                                           # Reduce window width with keyboard
bind = $mainMod SHIFT, l, resizeactive, 0 100                                            # Increase window height with keyboard
bind = $mainMod SHIFT, k, resizeactive, 0 -100                                             # Reduce window height with keyboard
bind = $mainMod, G, togglegroup                                                             # Toggle window group
bind = $mainMod, `, swapsplit                                                               # Swapsplit

bind = $mainMod ALT, j, swapwindow, l                                                    # Swap tiled window left
bind = $mainMod ALT, semicolon, swapwindow, r                                                   # Swap tiled window right
bind = $mainMod ALT, l, swapwindow, u                                                      # Swap tiled window up
bind = $mainMod ALT, k, swapwindow, d                                                    # Swap tiled window down

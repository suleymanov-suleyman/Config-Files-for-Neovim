#This config for hyprland ml4w .config/hypr/conf/custom.conf
# Unbind old shortcuts
unbind = $mainMod, w
unbind = $mainMod, q
unbind = $mainMod, j
unbind = $mainMod, semicolon
unbind = $mainMod, l
unbind = $mainMod, k
unbind = $mainMod SHIFT, j
unbind = $mainMod SHIFT, semicolon
unbind = $mainMod SHIFT, l
unbind = $mainMod SHIFT, k
unbind = $mainMod, grave
unbind = $mainMod ALT, j
unbind = $mainMod ALT, semicolon
unbind = $mainMod ALT, l
unbind = $mainMod ALT, k
unbind = $mainMod, n
unbind = $mainMod, h

# Switch capslook and escape
input {
    kb_options = caps:swapescape 
}

exec-once = vicinae server

# Vicinae applications manager
bind = $mainMod, w, exec, vicinae toggle

bind = $mainMod, grave, killactive                                      
bind = $mainMod, h, swapsplit
bind = $mainMod, n,togglesplit

# Focus
bind = $mainMod, j, movefocus, l                                    
bind = $mainMod, semicolon, movefocus, r                            
bind = $mainMod, l, movefocus, u                                    
bind = $mainMod, k, movefocus, d                                    

# Resize
bind = $mainMod SHIFT, j, resizeactive, 100 0                       
bind = $mainMod SHIFT, semicolon, resizeactive, -100 0              
bind = $mainMod SHIFT, l, resizeactive, 0 100                       
bind = $mainMod SHIFT, k, resizeactive, 0 -100                      

# Group
bind = $mainMod, G, togglegroup                                     

# Swap
bind = $mainMod ALT, j, swapwindow, l                               
bind = $mainMod ALT, semicolon, swapwindow, r                       
bind = $mainMod ALT, l, swapwindow, u                               
bind = $mainMod ALT, k, swapwindow, d
